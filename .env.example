# RAGNAR — environment configuration
# Copy this file to .env and adjust values. Never commit a real .env.

# --- Core ---
DEBUG=False
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated). Use your real domains in production.
# Example: https://ragnar.gg,https://www.ragnar.gg
ALLOWED_ORIGINS=*

# --- Storage ---
# SQLite by default (zero setup). Swap for Postgres in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/ragnar
DATABASE_URL=sqlite:///./ragnar.db

# --- Fee model (the value proposition) ---
RAGNAR_STANDARD_RATE=0.05
RAGNAR_FOUNDING_RATE=0.04
PROCESSING_RATE=0.029
PROCESSING_FLAT=0.30

# eBay comparison estimate (trading-card final value fees ~13.25% + flat)
EBAY_FEE_RATE=0.1325
EBAY_FLAT_FEE=0.30

# --- Founding 250 program ---
FOUNDING_SELLER_CAP=250
FOUNDING_INTRO_DAYS=90
FOUNDING_INTRO_SALES_CAP=2500

# --- Uploads (scan-to-post photos) ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=12

# --- Scan / card recognition ---
# auto = Ximilar if token set, else OpenAI vision if key set, else filename heuristic
# ximilar | openai | heuristic/none
SCAN_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
# Ximilar collectibles recognition — https://app.ximilar.com/login
XIMILAR_TOKEN=
XIMILAR_BASE=https://api.ximilar.com/tagging/collectibles/v2
XIMILAR_ENDPOINT=tcg_id     # tcg_id | sport_id | slab_id

# --- Live pricing: TCG API (https://tcgapi.dev, free key = 100/day) ---
TCG_API_BASE=https://api.tcgapi.dev
TCG_API_KEY=

# --- Sold comps / sales history (external provider; SoldComps shape by default) ---
# e.g. COMPS_PROVIDER_URL=https://api.sold-comps.com/v1/sold  (confirm exact path in their docs)
COMPS_PROVIDER=soldcomps
COMPS_PROVIDER_URL=
COMPS_PROVIDER_KEY=
COMPS_AUTH_HEADER=X-API-Key
COMPS_LOOKBACK_DAYS=365

# --- PSA population/authentication (OAuth2; docs behind login) — stub seam ---
PSA_ACCESS_TOKEN=
PSA_BASE=https://api.psacard.com/publicapi

# --- Payments (Stripe Connect) ---
# Use TEST keys first (sk_test_… / pk_test_…) from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` or the Stripe Dashboard webhook config
STRIPE_WEBHOOK_SECRET=
PLATFORM_CURRENCY=usd
# Public URL of this app (for Stripe onboarding return + checkout redirect links)
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Flip to True only once you've moved to live keys and tested end-to-end
PAYMENTS_LIVE=False
