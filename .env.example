# RAGNAR — environment configuration
# Copy this file to .env and adjust values. Never commit a real .env.

# --- Core ---
# development | production
# production: refuses to boot if CORS/Stripe/email/schema checks fail;
#             disables SQLModel create_all (use Alembic instead).
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO
# Schema bootstrap: leave empty (auto), or force create_all | alembic
# SCHEMA_BOOTSTRAP=alembic

# CORS allowed origins (comma-separated). NEVER use * in production with cookies.
# Example production:
# ALLOWED_ORIGINS=https://ragnarips.com,https://www.ragnarips.com
ALLOWED_ORIGINS=*

# Canonical public URLs (https required in production)
PUBLIC_BASE_URL=http://127.0.0.1:8000
SITE_URL=http://127.0.0.1:8000

# --- Storage ---
# SQLite by default (zero setup). For production cutover, prefer Supabase below.
DATABASE_URL=sqlite:///./ragnar.db
# Production: alembic upgrade head, then SCHEMA_BOOTSTRAP=alembic
SEED_DEMO=False

# --- Supabase (target data platform; Roadmap Phase 1) ---
# On Render, set these in the dashboard (Environment). When SUPABASE_DB_URL is
# set, the app uses it instead of DATABASE_URL. Set USE_SUPABASE_DB=false to
# force the SQLite/DATABASE_URL fallback.
# SUPABASE_DB_URL=postgresql://postgres.tmlwajtttnkhkmrsdnie:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres
USE_SUPABASE_DB=false
SUPABASE_DB_URL=
# Client keys for auth/storage/realtime (unset = off).
# Prefer SUPABASE_URL (SUPA_URL is accepted as an alias).
SUPABASE_URL=https://tmlwajtttnkhkmrsdnie.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
# Legacy aliases (optional if publishable/secret are set):
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Automation (n8n) ---
# Example: N8N_WEBHOOK_BASE=https://n8n.ragnarips.com/webhook
# Backend POSTs to <base>/<event.name> (seller.applied, order.paid, …).
# Unset = automation off (emit is a safe no-op). See vault Automation docs.
N8N_WEBHOOK_BASE=
N8N_WEBHOOK_SECRET=

# --- Fee model (the value proposition) ---
RAGNAR_STANDARD_RATE=0.05
RAGNAR_FOUNDING_RATE=0.04
PROCESSING_RATE=0.029
PROCESSING_FLAT=0.30

# eBay comparison estimate (trading-card final value fees ~13.25% + flat)
EBAY_FEE_RATE=0.1325
EBAY_FLAT_FEE=0.30

# --- Founding 250 program ---
FOUNDING_SELLER_CAP=250
FOUNDING_INTRO_DAYS=90
FOUNDING_INTRO_SALES_CAP=2500

# --- Uploads (scan-to-post photos) ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=12

# --- Scan / card recognition ---
# auto = Ximilar if token set, else OpenAI vision if key set, else filename heuristic
# ximilar | openai | heuristic/none
SCAN_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
# Ximilar collectibles recognition — https://app.ximilar.com/login
XIMILAR_TOKEN=
XIMILAR_BASE=https://api.ximilar.com/tagging/collectibles/v2
XIMILAR_ENDPOINT=tcg_id     # tcg_id | sport_id | slab_id

# --- Live pricing: TCG API (https://tcgapi.dev, free key = 100/day) ---
TCG_API_BASE=https://api.tcgapi.dev
TCG_API_KEY=

# --- Sold comps / sales history (external provider; SoldComps shape by default) ---
# e.g. COMPS_PROVIDER_URL=https://api.sold-comps.com/v1/sold  (confirm exact path in their docs)
COMPS_PROVIDER=soldcomps
COMPS_PROVIDER_URL=
COMPS_PROVIDER_KEY=
COMPS_AUTH_HEADER=X-API-Key
COMPS_LOOKBACK_DAYS=365

# --- PSA population/authentication (OAuth2; docs behind login) — stub seam ---
PSA_ACCESS_TOKEN=
PSA_BASE=https://api.psacard.com/publicapi

# --- Payments (Stripe Connect) ---
# Use TEST keys first (sk_test_… / pk_test_…) from https://dashboard.stripe.com/test/apikeys
# Production checklist:
#   STRIPE_SECRET_KEY=sk_live_…
#   STRIPE_PUBLISHABLE_KEY=pk_live_…
#   STRIPE_WEBHOOK_SECRET=whsec_…  (Dashboard webhook → checkout.session.completed + expired)
#   PAYMENTS_LIVE=True
#   PUBLIC_BASE_URL / SITE_URL = https://your-domain
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` or the Stripe Dashboard webhook config
STRIPE_WEBHOOK_SECRET=
PLATFORM_CURRENCY=usd
# Flip to True only once you've moved to live keys and tested end-to-end
PAYMENTS_LIVE=False

# --- Email (Resend) — required in production for verify + password reset ---
RESEND_API_KEY=
EMAIL_FROM=RAGNAR <notifications@ragnarips.com>

# --- AI Support OS ---
# Confidence bands: >= AUTONOMOUS + low risk → AI resolves alone
# REVIEW..AUTONOMOUS or medium risk → act + flag for later review
# < REVIEW or high risk → human queue
SUPPORT_CONF_AUTONOMOUS=0.90
SUPPORT_CONF_REVIEW=0.70
# Max refund (cents) AI may issue without escalating to high_value queue
SUPPORT_AI_MAX_REFUND_CENTS=50000
